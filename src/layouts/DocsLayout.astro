---
import '../styles/global.css';
import { Globe, List, Moon, PanelLeftClose, PanelLeftOpen, Sun } from '@lucide/astro';
import { nav } from '../data/nav.js';

const { title = 'LiRAYS SCADA Docs', currentPath = '/' } = Astro.props;
const normalizePath = (path) => {
  if (!path || path === '/') return '/';
  return path.replace(/\/+$/, '');
};
const isActive = (href) => {
  return normalizePath(currentPath) === normalizePath(href);
};
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Documentation for installation, operations, integrations, and development" />
    <meta name="theme-color" content="#0f1118" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <nav>
          {
            nav.map((item) =>
              item.children ? (
                <section class="nav-group">
                  <p class="nav-group-title">{item.title}</p>
                  <ul>
                    {item.children.map((child) => (
                      <li>
                        <a href={child.href} class={isActive(child.href) ? 'active' : ''}>{child.title}</a>
                      </li>
                    ))}
                  </ul>
                </section>
              ) : (
                <section class="nav-group">
                  <ul>
                    <li>
                      <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.title}</a>
                    </li>
                  </ul>
                </section>
              ),
            )
          }
        </nav>
      </aside>
      <main class="content">
        <header class="content-header">
          <div class="content-header-controls">
            <button
              type="button"
              id="nav-toggle"
              class="nav-toggle icon-button"
              aria-label="Hide index"
              title="Hide index"
              aria-expanded="true"
              data-nav-open="true"
            >
              <span class="sr-only">Toggle index</span>
              <span class="icon-stack" aria-hidden="true">
                <PanelLeftClose class="icon-state icon-state-open" size={16} strokeWidth={2.2} />
                <PanelLeftOpen class="icon-state icon-state-closed" size={16} strokeWidth={2.2} />
              </span>
            </button>
            <button
              type="button"
              id="toc-toggle"
              class="toc-toggle icon-button"
              aria-label="Toggle On This Page"
              title="Toggle On This Page"
              aria-expanded="false"
            >
              <span class="sr-only">Toggle On This Page</span>
              <List size={16} strokeWidth={2.2} aria-hidden="true" />
            </button>
          </div>
          <a href="/" class="header-brand" aria-label="LiRAYS SCADA">
            <img src="/logo.svg" alt="LiRAYS" class="header-brand-logo" draggable="false" />
            <span class="header-brand-suffix">SCADA</span>
          </a>
          <div class="content-header-actions">
            <a
              href="https://www.lirays.com?utm_source=help.lirays.com&utm_medium=referral&utm_campaign=docs_nav&utm_content=main_site_button"
              class="site-link icon-button"
              aria-label="Home Page"
              title="Home Page"
              target="_blank"
              rel="noopener external"
            >
              <Globe size={16} strokeWidth={2.2} aria-hidden="true" />
              <span class="sr-only">Home Page</span>
            </a>
            <a
              href="https://github.com/LiRAYSgj/LiRAYS-Scada?utm_source=help.lirays.com&utm_medium=referral&utm_campaign=docs_nav&utm_content=github_header_button"
              class="github-link icon-button"
              aria-label="LiRAYS SCADA GitHub repository"
              title="LiRAYS SCADA GitHub repository"
              target="_blank"
              rel="noopener external"
            >
              <span class="sr-only">Open GitHub repository</span>
              <svg
                viewBox="0 0 24 24"
                width="16"
                height="16"
                aria-hidden="true"
                fill="currentColor"
                role="img"
              >
                <path
                  d="M12 1.5a10.5 10.5 0 0 0-3.32 20.46c.52.1.7-.22.7-.5v-1.72c-2.86.62-3.46-1.22-3.46-1.22-.46-1.17-1.13-1.48-1.13-1.48-.93-.64.07-.62.07-.62 1.03.07 1.57 1.05 1.57 1.05.91 1.56 2.4 1.11 2.98.85.09-.66.36-1.11.65-1.37-2.28-.26-4.68-1.14-4.68-5.08 0-1.12.4-2.04 1.05-2.76-.1-.26-.46-1.32.1-2.76 0 0 .86-.28 2.82 1.05a9.8 9.8 0 0 1 5.14 0c1.96-1.33 2.82-1.05 2.82-1.05.56 1.44.2 2.5.1 2.76.65.72 1.05 1.64 1.05 2.76 0 3.95-2.4 4.81-4.69 5.07.37.32.7.95.7 1.92v2.84c0 .28.19.61.71.5A10.5 10.5 0 0 0 12 1.5Z"
                />
              </svg>
            </a>
            <button
              type="button"
              id="theme-toggle"
              class="theme-toggle icon-button"
              aria-label="Switch to dark mode"
              title="Switch to dark mode"
              aria-pressed="false"
              data-theme="light"
            >
              <span class="sr-only">Toggle theme</span>
              <span class="theme-toggle-icon" aria-hidden="true">
                <Moon class="theme-icon theme-icon-moon" size={16} strokeWidth={2.2} />
                <Sun class="theme-icon theme-icon-sun" size={16} strokeWidth={2.2} />
              </span>
            </button>
          </div>
        </header>
        <div class="content-body">
          <article class="doc-content">
            <slot />
          </article>
          <aside id="toc-panel" class="toc-panel" aria-label="Table of contents">
            <div class="toc-card">
              <h2 class="toc-title">On This Page</h2>
              <nav id="toc-nav" class="toc-nav">
                <p class="toc-empty">No sections on this page.</p>
              </nav>
            </div>
          </aside>
          <button type="button" id="toc-backdrop" class="toc-backdrop" aria-label="Close table of contents"></button>
        </div>
      </main>
    </div>
    <button type="button" id="nav-backdrop" class="nav-backdrop" aria-label="Close index"></button>
    <script>
      const root = document.documentElement;
      const btn = document.getElementById('theme-toggle');
      const body = document.body;
      const navToggle = document.getElementById('nav-toggle');
      const navBackdrop = document.getElementById('nav-backdrop');
      const sidebarLinks = document.querySelectorAll('.sidebar nav a');
      const tocToggle = document.getElementById('toc-toggle');
      const tocBackdrop = document.getElementById('toc-backdrop');
      const tocNav = document.getElementById('toc-nav');
      const docContent = document.querySelector('.doc-content');
      const DESKTOP_BREAKPOINT = 1200;
      const SIDEBAR_DESKTOP_BREAKPOINT = 961;

      const applyTheme = (theme) => {
        const isDark = theme === 'dark';
        root.setAttribute('data-theme', theme);
        btn?.setAttribute('aria-pressed', String(isDark));
        btn?.setAttribute('data-theme', theme);
        if (btn) {
          const nextLabel = isDark ? 'Switch to light mode' : 'Switch to dark mode';
          btn.setAttribute('aria-label', nextLabel);
          btn.setAttribute('title', nextLabel);
        }
      };

      const saved = localStorage.getItem('theme');
      const preferredDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const initial = saved || (preferredDark ? 'dark' : 'light');
      applyTheme(initial);

      btn?.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        applyTheme(next);
        localStorage.setItem('theme', next);
      });

      const navDesktop = window.matchMedia(`(min-width: ${SIDEBAR_DESKTOP_BREAKPOINT}px)`);
      const isNavDesktop = () => navDesktop.matches;
      const savedNavOpen = localStorage.getItem('nav-open');
      let navOpen = savedNavOpen === null ? true : savedNavOpen === 'true';

      const setNavOpen = (value, persist = true) => {
        navOpen = value;
        body.dataset.navOpen = String(value);
        navToggle?.setAttribute('aria-expanded', String(value));
        navToggle?.setAttribute('data-nav-open', String(value));
        const navLabel = value ? 'Hide index' : 'Show index';
        navToggle?.setAttribute('aria-label', navLabel);
        navToggle?.setAttribute('title', navLabel);
        if (isNavDesktop()) {
          if (persist) localStorage.setItem('nav-open', String(value));
        }
      };

      const syncNavState = () => {
        if (isNavDesktop()) {
          const desktopSaved = localStorage.getItem('nav-open');
          setNavOpen(desktopSaved === null ? true : desktopSaved === 'true', false);
        } else {
          setNavOpen(false, false);
        }
      };

      syncNavState();
      navDesktop.addEventListener('change', syncNavState);

      navToggle?.addEventListener('click', () => {
        setNavOpen(!navOpen);
      });

      navBackdrop?.addEventListener('click', () => {
        if (!isNavDesktop()) setNavOpen(false, false);
      });

      sidebarLinks.forEach((link) => {
        link.addEventListener('click', () => {
          if (!isNavDesktop()) setNavOpen(false, false);
        });
      });

      const mediaDesktop = window.matchMedia(`(min-width: ${DESKTOP_BREAKPOINT}px)`);
      const hasDesktopToc = () => mediaDesktop.matches;
      const savedVisible = localStorage.getItem('toc-visible');
      let tocVisible = savedVisible === null ? true : savedVisible === 'true';
      let tocOpen = false;

      const setTocVisible = (value, persist = true) => {
        tocVisible = value;
        if (persist) localStorage.setItem('toc-visible', String(value));
        body.dataset.tocVisible = String(value);
        const toggleLabel = value ? 'Hide On This Page' : 'Show On This Page';
        tocToggle?.setAttribute('aria-label', toggleLabel);
        tocToggle?.setAttribute('title', toggleLabel);
        tocToggle?.setAttribute('aria-expanded', String(value));
        if (value) {
          tocOpen = false;
          body.dataset.tocOpen = 'false';
        }
      };

      const setTocOpen = (value) => {
        tocOpen = value;
        body.dataset.tocOpen = String(value);
        tocToggle?.setAttribute('aria-expanded', String(value));
        const toggleLabel = value ? 'Hide On This Page' : 'Show On This Page';
        tocToggle?.setAttribute('aria-label', toggleLabel);
        tocToggle?.setAttribute('title', toggleLabel);
      };

      const slugify = (text) =>
        text
          .toLowerCase()
          .trim()
          .replace(/['"]/g, '')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/(^-|-$)/g, '');

      const ensureHeadingId = (heading, usedIds) => {
        const existing = heading.id?.trim();
        if (existing) {
          usedIds.add(existing);
          return existing;
        }
        const base = slugify(heading.textContent || 'section') || 'section';
        let nextId = base;
        let i = 2;
        while (usedIds.has(nextId)) {
          nextId = `${base}-${i}`;
          i += 1;
        }
        heading.id = nextId;
        usedIds.add(nextId);
        return nextId;
      };

      const headings = docContent ? Array.from(docContent.querySelectorAll('h2, h3')) : [];
      const usedIds = new Set();
      const items = headings.map((heading) => {
        const id = ensureHeadingId(heading, usedIds);
        return {
          id,
          text: (heading.textContent || '').trim(),
          depth: heading.tagName.toLowerCase(),
          node: heading,
        };
      });

      if (!tocNav || items.length === 0) {
        tocToggle?.setAttribute('disabled', 'true');
      } else {
        tocNav.innerHTML = '';
        const list = document.createElement('ul');
        list.className = 'toc-list';

        const linksById = new Map();
        for (const item of items) {
          const li = document.createElement('li');
          li.className = `toc-item toc-item-${item.depth}`;
          const a = document.createElement('a');
          a.href = `#${item.id}`;
          a.textContent = item.text;
          a.className = 'toc-link';
          li.appendChild(a);
          list.appendChild(li);
          linksById.set(item.id, a);
        }
        tocNav.appendChild(list);

        const updateActive = () => {
          let activeId = items[0]?.id;
          for (const item of items) {
            if (item.node.getBoundingClientRect().top <= 132) {
              activeId = item.id;
            }
          }
          linksById.forEach((link, id) => {
            link.classList.toggle('active', id === activeId);
          });
        };
        updateActive();
        window.addEventListener('scroll', updateActive, { passive: true });

        tocNav.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            if (!hasDesktopToc() || !tocVisible) {
              setTocOpen(false);
            }
          });
        });
      }

      const syncTocState = () => {
        if (!hasDesktopToc()) {
          setTocVisible(false, false);
        } else {          
          const desktopSaved = localStorage.getItem('toc-visible');
          setTocVisible(desktopSaved === null ? true : desktopSaved === 'true', false);
        }
        setTocOpen(false);
      };

      setTocVisible(tocVisible);
      syncTocState();
      mediaDesktop.addEventListener('change', syncTocState);

      tocToggle?.addEventListener('click', () => {
        if (hasDesktopToc()) {
          setTocVisible(!tocVisible);
          return;
        }
        setTocOpen(!tocOpen);
      });

      tocBackdrop?.addEventListener('click', () => {
        setTocOpen(false);
      });
    </script>
  </body>
</html>
