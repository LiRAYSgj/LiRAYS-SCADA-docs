---
const { lanes = [] } = Astro.props;

const rows = lanes.flatMap((lane) => {
  if (!lane.items?.length) {
    return [
      {
        goal: 'No items yet',
        status: '—',
        window: '—',
        notes: '—',
      },
    ];
  }

  return lane.items.map((item) => ({
    goal: item.goal,
    status: item.status,
    window: item.window,
    notes: item.notes,
  }));
});
---

<div class="timeline-table-wrap">
  <table class="timeline-table">
    <colgroup>
      <col style="width: 30%;" />
      <col style="width: 15%;" />
      <col style="width: 20%;" />
      <col style="width: 35%;" />
    </colgroup>
    <thead>
      <tr>
        <th scope="col">Goal</th>
        <th scope="col">Status</th>
        <th scope="col">Target Window</th>
        <th scope="col">Notes</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr>
            <td>{row.goal}</td>
            <td>{row.status}</td>
            <td><code>{row.window}</code></td>
            <td>{row.notes}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  .timeline-table-wrap {
    width: 100%;
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    background: var(--card);
  }

  .timeline-table {
    width: 100%;
    table-layout: fixed;
    border-collapse: collapse;
    min-width: 760px;
  }

  .timeline-table th,
  .timeline-table td {
    border-bottom: 1px solid var(--border);
    padding: 0.75rem 0.8rem;
    text-align: left;
    vertical-align: top;
    overflow-wrap: anywhere;
  }

  .timeline-table thead th {
    position: sticky;
    top: 0;
    background: color-mix(in srgb, var(--card) 92%, var(--muted));
    z-index: 1;
  }

  .timeline-table tbody tr:nth-child(odd) {
    background: color-mix(in srgb, var(--card) 95%, var(--muted));
  }

  .timeline-table tbody tr:last-child td {
    border-bottom: 0;
  }
</style>
